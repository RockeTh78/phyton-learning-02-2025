# Website Generator Agent — Environment Variables
# Copy this to .env and fill in your values.

# Anthropic API (required for website generation)
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare (required for domain registration + DNS)
# Setup:
#   1. Create account at cloudflare.com
#   2. Add payment method: dash.cloudflare.com > Billing > Payment Methods
#   3. Create API token: dash.cloudflare.com > My Profile > API Tokens
#      Permissions needed: "Registrar: Edit" + "Zone: DNS: Edit"
#   4. Find Account ID: any zone page > right sidebar
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Affiliate Partner IDs (used in generated websites)
AMAZON_TAG=yoursite-21
BOOKING_AID=YOUR_BOOKING_AID
GETYOURGUIDE_PARTNER_ID=YOUR_GYG_ID
SKYSCANNER_ASSOCIATE_ID=YOUR_SKYSCANNER_ID
